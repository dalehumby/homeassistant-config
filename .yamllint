# Configuration file for yamllint
# https://yamllint.readthedocs.io/en/stable/index.html

extends: default

ignore: |
  custom_components/
  .storage/

rules:
  indentation:
    spaces: 2
    indent-sequences: consistent
  line-length:
    max: 200
  document-start: disable
  truthy:
    allowed-values: ['true', 'false', 'on', 'off']
